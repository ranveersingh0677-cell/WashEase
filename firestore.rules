rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shops collection
    match /shops/{shopId} {
      // Allow anybody to register (create)
      // Allow read/update if authenticated (could be more restrictive)
      allow create: if true; 
      allow read, update, delete: if request.auth != null;
    }
    
    // Existing orders rules (assumed)
    match /orders/{orderId} {
      allow read, write: if true; // Should be more secure in production
    }

    // Existing users rules (assumed)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
